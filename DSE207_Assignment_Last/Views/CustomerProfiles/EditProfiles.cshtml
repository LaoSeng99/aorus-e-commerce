
@{
    ViewData["Title"] = "EditProfiles";
    Layout = "~/Views/Shared/Customer/Profiles_Layout.cshtml";
}


<div id="Acdetails" class="container mb-3" style="padding-left:60px;padding-right:60px;">
    <div class="row">
        <div class="col-xs-12">
            <div class="h1 page-title text-center mt-5 mb-2">My Account Details</div>
        </div>
        <div class="col-xs-12 col-md-4 my-2 text-center  float-left">
            <div class="bg-gray-333 p-3 rounded">
                <div class="member-img">
                    <img src="https://member.aorus.com/images/pic-default.jpg" alt="">
                </div>
                <h3><div id="User_Name_avatar">seghot ong</div></h3>
                <label for="edit-picture-btn" class="btn btn-black btn-block mt-2 edit-picture-btn">Edit Profile Picture</label>
                <input type="file" id="edit-picture-btn" style="display:none" />
            </div>
        </div>
        <div class="col-xs-12  col-md-8  float-left">
            <div class="row">
                <div class="col-sm-12 col-md-12">
                    <div class="row">

                        <div class="col-xs-12 col-sm-12 col-md-6  aorus-input float-left">
                            <input type="text" class="form-control" value="" id="Info_FirstName" maxlength="32">
                            <span class="title">First Name</span>
                        </div>
                        <div class="col-xs-12 col-sm-12 col-md-6  aorus-input float-left">
                            <input type="text" class="form-control" value="" id="Info_LastName" maxlength="32">
                            <span class="title">Last Name</span>
                        </div>
                        <div class="col-xs-12 col-sm-12  aorus-input float-left">

                            <input type="text" class="form-control" value="seghot ong" id="User_Name" maxlength="30">
                            <span class="title">Nickname<font color="#ff6400">*</font></span>

                        </div>
                        <div class="col-xs-12 col-sm-12  aorus-input float-left">
                            <input type="email" id="details_email" class="form-control" value="" disabled="">
                            <span class="title">Email<font color="#ff6400">*</font></span>
                        </div>
                        <div class="col-xs-12 col-sm-12  aorus-input float-left">

                            <input type="text" class="form-control"readonly id="locale2" value="" disabled=""><span class="title" id="locale-area">Country/Region</span>
                        </div>
                        <div class="col-xs-12 col-sm-12 col-md-6  aorus-input float-left">
                            <div class="select-arrow">
                                <i class="fa fa-angle-down"></i>
                            </div>
                            <select name="Info_Gender" id="Info_Gender" class="form-control">
                                <option value="">-- select --</option>
                                <option value="Male">Male</option>
                                <option value="Female">Female</option>
                                <option value="Privacy">Privacy</option>
                            </select>
                            <span class="title">Gender</span>
                        </div>



                        <div id="errorSave" style="display:none;">
                            <div class="col-xs-12 mt-3">
                                <div class="error-mes py-1 px-2">
                                </div>
                            </div>
                        </div>
                        <div class="col-xs-12 mt-2 text-center">
                            <button class="btn btn-orange px-5" id="saveInfoBtn">Save</button>
                        </div>


                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="window-box-cover">
    <div class="window-box">
        <div class="window-box-close"></div>
        <div class="container-fluid">
            <div class="row">
                <div class="col-xs-12 text-center">
                    <h2>Edit Profile Picture</h2>
                </div>
                <div class="col-xs-12 text-center my-2">
                    <div class="edit-img-div">
                        <div class="edit-img">
                            <img src="https://member.aorus.com/images/pic-default.jpg" alt="" id="user-pic-null" style="display:none;">
                            <img src="https://member.aorus.com/images/pic-default.jpg" alt="" id="user-pic-now">
                            <img src="" alt="" id="user-pic" style="display:none;">
                        </div>
                    </div>
                    <div class="text-right edit-img-btn mt-1">
                        <input type="file" id="userfile" name="upload" style="display:none;" accept="image/gif, image/jpeg, image/png">
                        <button class="btn btn-black deleteUserPicBtn"><i class="far fa-trash-alt"></i></button>
                        <button class="btn btn-orange uploadUserPicBtn"><i class="fa fa-upload"></i></button>
                        <div id="error_avatar" class="mt-3 text-left"></div>
                        <div class="row mt-3">

                            <div class="col-xs-12 col-sm-6 text-center">
                                <button class="btn btn-black btn-block py-1 backbtn">Back</button>
                            </div>
                            <div class="col-xs-12 col-sm-6 text-center">

                                <button class="btn btn-orange btn-block py-1" onclick="save_avatar();">Save</button>
                            </div>
                            <div class="col-xs-12 mt-1 text-orange text-left">
                                <p style="font-size: 14px">Allowed file type: jpg, png, gif. The maximum file size is 2MB.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/js/customer/EditDetails.js?3"></script>
<script src="~/js/customer/customerInputCheck.js?3"></script>
<script>

</script>