@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/Admin/Admin_Layout.cshtml";
}
<div class="card card-danger">
    <div class="card-header">
        <h3 class="card-title">Category Total Sales</h3>

        <div class="card-tools">
            <button type="button" class="btn btn-tool" data-card-widget="collapse">
                <i class="fas fa-minus"></i>
            </button>
            <button type="button" class="btn btn-tool" data-card-widget="remove">
                <i class="fas fa-times"></i>
            </button>
        </div>
    </div>
    <div class="card-body">
        <canvas id="pieChart" style="min-height: 250px; height: 250px; max-height: 250px; max-width: 100%;"></canvas>
    </div>
    <!-- /.card-body -->
</div>


<div class="card card-success">
    <div class="card-header">
        <h3 class="card-title">Top 3 Seller Orders:(2024)</h3>

        <div class="card-tools">
            <button type="button" class="btn btn-tool" data-card-widget="collapse">
                <i class="fas fa-minus"></i>
            </button>
            <button type="button" class="btn btn-tool" data-card-widget="remove">
                <i class="fas fa-times"></i>
            </button>
        </div>
    </div>
    <div class="card-body">
        <div class="chart">
            <canvas id="stackedBarChart" style="min-height: 250px; height: 250px; max-height: 250px; max-width: 100%;"></canvas>
        </div>
    </div>
    <!-- /.card-body -->
</div>

<!-- /.content -->
<script src="~/lib/jquery/dist/jquery.min.js"></script>


<script src="~/ExternalSide/Dashboard/plugins/flot/jquery.flot.js"></script>

<!-- FLOT CHARTS -->
<script src="~/js/admin/Dashboard.js?4"></script>
